# Optional. Leave unset only for loopback-only use or when an authenticated
# HTTPS reverse proxy protects every management route. Set a long random value
# to require ?token=... on every request.
# SESSION_RENAMER_TOKEN=

# Optional. Public HTTPS URL fronting the FRP tunnel, printed by frp-tunnel.sh
# and used for its public health check.
# SESSION_RENAMER_PUBLIC_URL=

# Optional Codex data locations.
CODEX_HOME=~/.codex
# SESSION_RENAMER_INDEX_PATH=~/.codex/session_index.jsonl

# Optional title generation. Without an API key, existing titles are kept unchanged.
SESSION_RENAMER_TITLE_PROVIDER=qwen
# SESSION_RENAMER_DASHSCOPE_API_KEY=
# SESSION_RENAMER_QWEN_MODEL=qwen3.5-flash
# SESSION_RENAMER_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# SESSION_RENAMER_QWEN_TIMEOUT=8
# SESSION_RENAMER_QWEN_PROXY=http://127.0.0.1:7897

# Optional server settings.
SESSION_RENAMER_HOST=127.0.0.1
SESSION_RENAMER_PORT=8891
SESSION_RENAMER_TITLE_WORKERS=6
# SESSION_RENAMER_CODEX_BIN=/path/to/codex
